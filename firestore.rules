rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['customer', 'driver'] &&
             (!data.has('status') || data.status in ['online', 'offline']) &&
             (!data.has('phone') || (data.phone is string || data.phone == null)) &&
             (!data.has('displayName') || (data.displayName is string || data.displayName == null)) &&
             (!data.has('email') || (data.email is string || data.email == null)) &&
             (!data.has('lastActive') || (data.lastActive is timestamp || data.lastActive == request.time));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerId', 'status', 'fuelType', 'location']) &&
             data.customerId == request.auth.uid &&
             data.status in ['pending', 'accepted', 'delivering', 'completed', 'cancelled'] &&
             data.location.lat is number && data.location.lng is number &&
             (!data.has('createdAt') || data.createdAt is timestamp);
    }

    function isValidSOS(data) {
      return data.keys().hasAll(['userId', 'location', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.status == 'active' &&
             (data.createdAt == request.time || data.createdAt is timestamp);
    }

    // Collection Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
    }

    match /orders/{orderId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        resource.data.status == 'pending' || 
        resource.data.customerId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      );
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isSignedIn() && (
        (resource.data.customerId == request.auth.uid && incoming().status in ['cancelled']) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver')
      );
    }

    match /sos_alerts/{alertId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidSOS(incoming());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver');
    }
  }
}
